{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "preserve",
    "paths": {
      "@components/*": ["./src/components/*"],
      "@data/*": ["./src/data/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@styles/*": ["./src/styles/*"]
    }
  },
  "mdx": {
    "plugins": [
      "remark-gfm",
      "remark-cjk-friendly",
      "remark-cjk-friendly-gfm-strikethrough",
      [
        "remark-attribute-list",
        {
          "allowNoSpaceBeforeName": true,
          "allowUnderscoreInId": true,
          "allowNoPosition": true
        }
      ]
    ]
  }
}
